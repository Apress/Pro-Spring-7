<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <contextListener class="ch.qos.logback.classic.jul.LevelChangePropagator">
        <resetJUL>true</resetJUL>
    </contextListener>

    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%highlight(%-5level) %green(%logger{15}) - %msg %n</pattern>
        </encoder>
    </appender>

    <logger name="com.apress.prospring7.classic.seven" level="debug"/>

    <logger name="org.springframework.orm" level="debug"/>
    <logger name="org.hibernate" level="info" />
   <!-- <logger name="org.hibernate.query.hql" level="TRACE" />-->

    <root level="info">
        <appender-ref ref="console" />
    </root>
</configuration>
