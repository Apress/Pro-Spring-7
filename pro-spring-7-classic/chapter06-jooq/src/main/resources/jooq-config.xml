<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<configuration xmlns="http://www.jooq.org/xsd/jooq-codegen-3.20.1.xsd">
    <!-- Configure the database connection here -->
    <jdbc>
        <driver>org.mariadb.jdbc.Driver</driver>
        <url>jdbc:mariadb://localhost:3306/musicdb</url>
        <user>prospring7</user>
        <password>prospring7</password>
    </jdbc>

    <generator>
        <name>org.jooq.codegen.JavaGenerator</name>
        <database>
            <name>org.jooq.meta.mariadb.MariaDBDatabase</name>
            <!-- The database schema (or in the absence of schema support, in your RDBMS this
                 can be the owner, user, database name) to be generated -->
            <inputSchema>musicdb</inputSchema>
            <includes>.*</includes>
            <excludes/>
        </database>

        <target>
            <!-- The destination package of your generated classes (within the destination directory) -->
            <packageName>com.apress.prospring7.classic.six.jooq.generated</packageName>
            <directory>PATH_TO_GENERATED_DIR</directory>
        </target>

        <generate>
            <pojos>true</pojos>
            <pojosToString>true</pojosToString>
            <daos>true</daos>
        </generate>

    </generator>
</configuration>
